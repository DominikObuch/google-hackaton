{
  "mcpServers": {
    "angular-cli": {
      "command": "npx",
      "args": ["ng", "mcp"]
    },
    "nx": {
      "command": "npx",
      "args": ["nx", "mcp"]
    },
    "qmd": {
      "command": "npx",
      "args": ["qmd", "mcp"]
    },
    "ng-diagram": {
      "command": "npx",
      "args": ["ng-diagram-mcp"]
    },
    "postgres": {
      "command": "npx",
      "args": [
        "--yes",
        "--quiet",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:postgres@localhost:5432/nestDb"
      ]
    }
  }
}
